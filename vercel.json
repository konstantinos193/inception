{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "elevate.chunkiesgaming.com"
        }
      ],
      "destination": "https://elevateart.xyz/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.elevateart.xyz"
        }
      ],
      "destination": "https://elevateart.xyz/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "http://www.elevateart.xyz"
        }
      ],
      "destination": "https://elevateart.xyz/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "http://elevateart.xyz"
        }
      ],
      "destination": "https://elevateart.xyz/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "Link",
          "value": "<https://elevateart.xyz>; rel=\"canonical\""
        }
      ]
    }
  ]
}
